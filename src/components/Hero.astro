---
import ArchMark from './ArchMark.astro';

interface Props {
  tagline: string;
  subtitle?: string;
  imageUrl?: string;
}
const { tagline, subtitle, imageUrl } = Astro.props;
---

<section
  class="relative bg-clay text-cream py-20 md:py-24 px-6"
  style={imageUrl ? `background-image: linear-gradient(rgba(42,37,32,0.55), rgba(42,37,32,0.55)), url('${imageUrl}'); background-size: cover; background-position: center;` : undefined}
>
  <div class="max-w-3xl mx-auto text-center">
    <ArchMark class="w-16 h-16 md:w-20 md:h-20 mx-auto mb-6 text-cream opacity-90" />
    <h1 class="text-5xl md:text-6xl font-serif mb-4 leading-tight">{tagline}</h1>
    {subtitle && <p class="text-lg md:text-xl opacity-90">{subtitle}</p>}
  </div>
</section>
