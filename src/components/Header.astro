---
import { SITE } from '../config';

const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: base, label: 'Home' },
  { href: `${base}about`, label: 'About' },
  { href: `${base}walks`, label: 'Walks' },
  { href: `${base}get-involved`, label: 'Get Involved' },
  { href: `${base}contact`, label: 'Contact' },
];
---

<header class="bg-cream border-b border-sand sticky top-0 z-10">
  <div class="max-w-5xl mx-auto px-6 py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-y-2">
    <a href={base} class="font-serif text-clay text-xl tracking-wide text-center sm:text-left">
      {SITE.name}
    </a>
    <nav class="flex flex-wrap gap-x-4 gap-y-1 text-xs sm:text-sm uppercase tracking-wider justify-center sm:justify-end">
      {navLinks.map(link => (
        <a href={link.href} class="text-ink hover:text-clay transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
