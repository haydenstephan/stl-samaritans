---
import { SITE } from '../config';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/walks', label: 'Walks' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="bg-cream border-b border-sand sticky top-0 z-10">
  <div class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-y-2">
    <a href="/" class="font-serif text-clay text-xl tracking-wide">
      {SITE.name}
    </a>
    <nav class="flex flex-wrap gap-x-5 gap-y-2 text-xs sm:text-sm uppercase tracking-wider justify-end">
      {navLinks.map(link => (
        <a href={link.href} class="text-ink hover:text-clay transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
