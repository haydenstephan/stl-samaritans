---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormWrapper from '../components/FormWrapper.astro';
import { CONTACT } from '../config';
---

<BaseLayout title="Contact">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-serif text-clay mb-6">Contact</h1>
    <p class="text-lg mb-10">
      Questions, comments, or interest in joining? Drop us a note.
    </p>

    <FormWrapper
      subject="Contact form message"
      successMessage={`Thanks — we'll get back to you. In the meantime, here's our GroupMe: ${CONTACT.groupMeInviteUrl}`}
    >
      <label class="block">
        <span class="text-sm uppercase tracking-wider text-clay">Your name</span>
        <input
          type="text"
          name="name"
          required
          class="mt-1 block w-full border border-warmth/40 bg-cream px-3 py-2 focus:outline-none focus:border-clay"
        />
      </label>
      <label class="block">
        <span class="text-sm uppercase tracking-wider text-clay">Email</span>
        <input
          type="email"
          name="email"
          required
          class="mt-1 block w-full border border-warmth/40 bg-cream px-3 py-2 focus:outline-none focus:border-clay"
        />
      </label>
      <label class="block">
        <span class="text-sm uppercase tracking-wider text-clay">Message</span>
        <textarea
          name="message"
          rows="5"
          required
          class="mt-1 block w-full border border-warmth/40 bg-cream px-3 py-2 focus:outline-none focus:border-clay"
        ></textarea>
      </label>
    </FormWrapper>
  </div>
</BaseLayout>
