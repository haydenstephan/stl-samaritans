---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import { Content as About } from '../content/about.md';

const base = import.meta.env.BASE_URL;

// Replace these with actual photo paths once Hayden adds them to public/images/
const photos = [
  { src: `${base}images/placeholder-1.svg`, alt: 'A street walk in downtown St. Louis' },
  { src: `${base}images/placeholder-2.svg`, alt: 'Annual retreat group photo' },
  { src: `${base}images/placeholder-3.svg`, alt: 'Board game night' },
];
---

<BaseLayout title="About">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-serif text-clay mb-8">About us</h1>
    <div class="prose prose-lg font-serif text-ink max-w-none">
      <About />
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 pb-16">
    <Gallery images={photos} />
  </div>

  <section class="max-w-3xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-serif text-clay mb-4">In the press</h2>
    <a
      href="https://www.stlouisreview.com/story/catholic-groups-aid-homeless-in-frigid-temps/"
      target="_blank"
      rel="noopener noreferrer"
      class="block bg-sand p-6 rounded border border-warmth/30 hover:border-clay transition-colors group"
    >
      <p class="text-xs uppercase tracking-wider text-clay mb-1">St. Louis Review · January 2025</p>
      <p class="font-serif text-lg text-ink mb-2 group-hover:text-clay transition-colors">Catholic groups aid homeless in frigid temps</p>
      <p class="text-sm text-ink/70">Jennifer Brinker profiles our Sunday walks during a stretch of dangerous winter weather.</p>
      <span class="text-xs uppercase tracking-wider text-clay mt-3 inline-block">Read on St. Louis Review →</span>
    </a>
  </section>
</BaseLayout>
